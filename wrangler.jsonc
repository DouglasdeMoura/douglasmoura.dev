{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "blog",
  "main": "src/worker.tsx",
  "compatibility_date": "2025-08-21",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "binding": "ASSETS",
  },
  "observability": {
    "enabled": true,
  },
  "routes": [
    {
      "pattern": "douglasmoura.dev",
      "custom_domain": true
    },
    {
      "pattern": "www.douglasmoura.dev",
      "custom_domain": true
    },
  ],
  "vars": {},
}
