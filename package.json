{
  "name": "@douglasdemoura/blog",
  "version": "1.0.0",
  "private": true,
  "description": "My personal blog",
  "keywords": [],
  "license": "MIT",
  "author": "",
  "type": "module",
  "main": "index.js",
  "imports": {
    "#*": "./src/*"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite dev",
    "dev:init": "rw-scripts dev-init",
    "preview": "vite preview",
    "worker:run": "rw-scripts worker-run",
    "clean": "rm -rf ./node_modules/.vite",
    "release": "rw-scripts ensure-deploy-env && pnpm run clean && pnpm run build && wrangler deploy",
    "generate": "rw-scripts ensure-env && wrangler types --include-runtime false",
    "check": "ultracite check",
    "types": "tsc",
    "fix": "ultracite fix",
    "postinstall": "mkdir -p public/katex/fonts && cp node_modules/katex/dist/katex.min.css public/katex/katex.min.css && cp node_modules/katex/dist/fonts/*.woff2 public/katex/fonts/",
    "prepare": "lefthook install",
    "cli": "tsx cli/index.ts"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "@orama/stemmers": "^3.1.18",
    "@phosphor-icons/react": "^2.1.10",
    "@shikijs/core": "^4.0.2",
    "@shikijs/engine-javascript": "^4.0.2",
    "@shikijs/langs": "^4.0.2",
    "@shikijs/themes": "^4.0.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "cmdk": "^1.1.1",
    "feed": "^5.2.0",
    "gray-matter": "^4.0.3",
    "katex": "^0.16.42",
    "md4x": "^0.0.25",
    "pino": "^10.3.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-server-dom-webpack": "19.2.4",
    "react-tweet": "^3.3.0",
    "react-wrap-balancer": "^1.1.1",
    "rwsdk": "1.0.4",
    "swr": "^2.4.1",
    "tailwindcss": "^4.2.2",
    "workers-og": "^0.0.27"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.30.1",
    "@cloudflare/workers-types": "4.20260317.1",
    "@sindresorhus/slugify": "^3.0.0",
    "@types/katex": "^0.16.8",
    "@types/node": "~25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "citty": "^0.2.1",
    "colorette": "^2.0.20",
    "consola": "^3.4.2",
    "lefthook": "^2.1.4",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "ultracite": "7.3.2",
    "vite": "7.3.1",
    "wrangler": "4.77.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook",
      "sharp",
      "workerd"
    ]
  }
}
